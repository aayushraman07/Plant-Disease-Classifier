cat > .gitignore << 'EOF'
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
env/
.venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Large files
*.keras
*.h5
*.hdf5
*.zip
models/*.keras

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# VS Code
.vscode/
*.code-workspace
EOF
